#!/bin/sh

status() {
	while true; do
		battery=$(cat /sys/class/power_supply/BAT0/capacity)
		network=$(iwctl station wlan0 show | awk 'NR==7 {print $3}')
		ram=$(free -m | awk 'NR==2 {print $3 "/" $2}')
		time=$(date +%R)
		volume=$(amixer get Master | awk -F"[][]" '/Mono:/{print $2}')
		echo "NET $network | RAM ${ram}M | VOL $volume | BAT $battery% | $time "
		sleep 3
	done
}

menu() {
	echo -e "chromium-browser\ntelegram-desktop" | wmenu -f "Spleen 15" -N "#3f3f3f" -n "#ffffff" -S "#7f7f7f" -s "#ffffff" | sh
}

init()  {
	desktop status | ergo -F 'Spleen 15' -b '#3f3f3f' &
	exec <&-
}

$1
