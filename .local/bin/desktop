font="Fantasque Sans Mono 19"
bg="#0f0f0f"
fg="#ffffff"


screenshot() {
	grim ~/screenshots/$(date +%s).png
}


status() {
	battery=$(cat /sys/class/power_supply/BAT0/capacity)
	network=$(iwctl station wlan0 show | awk 'NR==7 {print $3}')
	ram=$(free --mega | awk 'NR==2 {print $3 "/" $2}')
	time=$(date +%R)
	current=$(mpc current)
	music=$(echo "${current%.*}")
	volume=$(amixer get Master | awk -F"[][]" '/Mono:/{print $2}')
	echo "$music î‚³ NET $network î‚³ RAM $ram î‚³ VOL $volume î‚³ BAT $battery î‚³ $time "
}

status_loop() {
	while true; do
		status
		sleep 2
	done
}

init() {
	swaybg -i wallpapers/wallpaper.jpg -m fit -c "#0f0f0f" &
	desktop status_loop | ergo -f "$font" -b $bg -c $fg &
	cat > .cache/dwl
}

menu() {
	echo -e "$1" | wmenu -f "$font" -N $bg -n $fg -S $fg -s $bg
}


launcher() {
	menu "chromium-browser\ntelegram-desktop" | sh
}


wallpaper() {
	if [ -d ~/wallpapers ]
	then
		file=$(menu "$(ls -1 ~/wallpapers)")
		if [ -n "$file" ]; then
			path=~/wallpapers/$file
			pkill swaybg
			swaybg -i $path -m fit &
		fi
	fi
}

music() {
	file=$(menu "$(mpc ls)")
	mpc clear
	mpc add "$file"
	mpc play
}

main() {
	 $(menu "launcher\nwallpaper\nmusic")
}


$1

